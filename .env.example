# Copy this file to .env.local and fill only the values you need.
# .env.local is ignored by Git and is the manual local config file.

# Tripp app / bridge ports
PORT=4177
HOST=127.0.0.1
TRIPP_BRIDGE_PORT=4317
TRIPP_BRIDGE_HOST=127.0.0.1

# Optional backend bridge
TRIPP_BACKEND_URL=http://127.0.0.1:4317
TRIPP_ENABLE_BACKEND_REPLY=true
TRIPP_BACKEND_HEALTH_PATH=/health
TRIPP_BACKEND_SECRET=

# Optional legacy runtime bridge
GOOSE_AGENT_URL=
GOOSED_PATH=

# Provider keys are not used directly by Tripp.g yet.
# Tripp.g can seed local Connections from these values on server startup.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Local provider connection seeding
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-chat
DEEPSEEK_CONNECTION_NAME=DeepSeek local env
DEEPSEEK_DEFAULT_PROMPT=true
DEEPSEEK_PURPOSES=default_prompt_testing,default_chat,read_only_planning,synthesis,fallback
TRIPP_PROVIDER_TLS_INSECURE=false

# OAuth managed providers
# Tokens default to ~/.kimi-tripp/oauth-tokens; override only when testing.
TRIPP_OAUTH_TOKEN_DIR=
TRIPP_OAUTH_CALLBACK_PORT=1455
CHATGPT_CODEX_CLIENT_ID=app_EMoamEEZ73f0CkXaXp7hrann
CHATGPT_CODEX_REDIRECT_URI=http://localhost:1455/callback
CHATGPT_CODEX_AUTH_URL=https://auth.openai.com/authorize
CHATGPT_CODEX_TOKEN_URL=https://auth.openai.com/token
CHATGPT_CODEX_SCOPES=openid profile email offline_access
CHATGPT_CODEX_EXTRA_PARAMS=

TRIPP_SEED_OLLAMA=true
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=kimi-k2.6:cloud
OLLAMA_CONNECTION_NAME=Ollama Kimi K2.6
OLLAMA_DEFAULT_PROMPT=true
OLLAMA_PURPOSES=default_prompt_testing,default_chat,coder_primary,fallback

TRIPP_SEED_OLLAMA_ALT=true
OLLAMA_ALT_BASE_URL=http://127.0.0.1:11434
OLLAMA_ALT_MODEL=nemotron-3-super:cloud
OLLAMA_ALT_CONNECTION_NAME=Ollama Nemotron
OLLAMA_ALT_DEFAULT_PROMPT=false
OLLAMA_ALT_PURPOSES=coder_secondary,verifier
