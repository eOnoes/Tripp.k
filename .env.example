# Copy this file to .env.local and fill only the values you need.
# .env.local is ignored by Git and is the manual local config file.

# Tripp app / bridge ports
PORT=4177
HOST=127.0.0.1
TRIPP_BRIDGE_PORT=4317
TRIPP_BRIDGE_HOST=127.0.0.1

# Optional backend bridge
TRIPP_BACKEND_URL=http://127.0.0.1:4317
TRIPP_ENABLE_BACKEND_REPLY=true
TRIPP_BACKEND_HEALTH_PATH=/health
TRIPP_BACKEND_SECRET=

# Optional legacy runtime bridge
GOOSE_AGENT_URL=
GOOSED_PATH=

# Provider keys are not used directly by Tripp.g yet.
# Put them here only for a backend process or bridge that reads them.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
